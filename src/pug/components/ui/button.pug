mixin button(text, type = 'primary', isDisabled = false)
  button(
    class=[
      'px-4 py-2 rounded-lg font-semibold transition-colors',
      type === 'primary' && 'bg-blue-500 text-white hover:bg-blue-600',
      type === 'secondary' && 'bg-gray-500 text-white hover:bg-gray-600',
      type === 'outline' && 'border border-blue-500 text-blue-500 hover:bg-blue-50',
      type === 'danger' && 'bg-red-500 text-white hover:bg-red-600',
      isDisabled && 'opacity-50 cursor-not-allowed'
    ],
    disabled=isDisabled
  )= text